{
  "name": "qtassist_self_evolution_system",
  "description": "量化交易助手自我进化系统 - 提供量化交易的自动化分析、预测和优化功能。此技能可帮助AI进行量化交易策略的分析、优化和预测，支持趋势跟踪、均值回归、统计套利、多因子模型和机器学习方法。",
  "version": "1.0.0",
  "api_version": "v1",
  "tools": [
    {
      "type": "function",
      "function": {
        "name": "get_system_status",
        "description": "获取自我进化系统的运行状态，包括各模块是否正常工作、系统阶段、心跳时间等。",
        "parameters": {
          "type": "object",
          "properties": {},
          "required": []
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "get_performance_metrics",
        "description": "获取系统性能指标，包括CPU使用率、内存使用率、磁盘使用率、函数执行时间等实时数据。",
        "parameters": {
          "type": "object",
          "properties": {
            "refresh": {
              "type": "boolean",
              "description": "是否强制刷新数据",
              "default": false
            }
          },
          "required": []
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "get_performance_trend",
        "description": "获取性能趋势数据，可在指定时间范围内绘制性能变化曲线。",
        "parameters": {
          "type": "object",
          "properties": {
            "minutes": {
              "type": "integer",
              "description": "时间范围(分钟)，可选5/15/30/60",
              "default": 5,
              "enum": [5, 15, 30, 60]
            }
          },
          "required": ["minutes"]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "get_ml_predictions",
        "description": "获取机器学习预测结果，包括功能预测、性能预测和异常检测。",
        "parameters": {
          "type": "object",
          "properties": {
            "prediction_type": {
              "type": "string",
              "description": "预测类型",
              "enum": ["function", "performance", "anomaly", "all"],
              "default": "all"
            }
          },
          "required": []
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "get_module_status",
        "description": "获取各功能模块的状态，包括使用跟踪、需求分析、自动优化、自动安装、新功能创建、机器学习和实时监控模块。",
        "parameters": {
          "type": "object",
          "properties": {},
          "required": []
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "get_alerts",
        "description": "获取系统警报，包括错误、警告和信息性消息。",
        "parameters": {
          "type": "object",
          "properties": {
            "hours": {
              "type": "integer",
              "description": "时间范围(小时)",
              "default": 24
            }
          },
          "required": []
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "start_evolution_system",
        "description": "启动自我进化系统，开始自动化分析和优化流程。",
        "parameters": {
          "type": "object",
          "properties": {},
          "required": []
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "stop_evolution_system",
        "description": "停止自我进化系统。",
        "parameters": {
          "type": "object",
          "properties": {},
          "required": []
        }
      }
    }
  ],
  "supported_platforms": [
    "claude_code",
    "openai",
    "anthropic",
    "mistral_hermes",
    "ollama",
    "lmstudio",
    "llama.cpp",
    "custom"
  ],
  "endpoint": {
    "base_url": "http://localhost:5001",
    "api_prefix": "/api"
  },
  "authentication": {
    "type": "none",
    "description": "本地部署，无需认证"
  }
}